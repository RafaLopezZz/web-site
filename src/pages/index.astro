---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import Navbar from "../components/Navbar.astro";
import SkillsPanel from "../components/SkillsPanel.astro";
import TimelineEducation from "../components/TimelineEducation.astro";
import TimelineExperience from "../components/TimelineExperience.astro";
import profileImage from "../assets/foto-perfil.jpg";
import profileImage2 from "../assets/foto-perfil2.png";
import cosechaEnCopeCover from "../assets/projects/portada.png";
import importadorDBCover from "../assets/projects/importador-db.png";
import gleaNexoCover from "../assets/projects/glea-nexo.png";
import { experience } from "../data/experience";
import { education } from "../data/education";
import type { CollectionEntry } from "astro:content";

const projects: CollectionEntry<"projects">[] = (
  await getCollection("projects")
).sort(
  (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
    b.data.date.getTime() - a.data.date.getTime(),
);
const projectImages = {
  "cosecha-en-cope": cosechaEnCopeCover,
  "importador-db": importadorDBCover,
  "glea-nexo": gleaNexoCover,
};
---

<BaseLayout>
  <Navbar />
  <main id="main-content" class="editorial-container py-10 md:py-14">
    <section
      id="top"
      class="border-b border-white/10 pb-12 pt-8 md:pb-16 md:pt-12"
    >
      <p class="mb-6 text-xs uppercase tracking-[0.28em] text-accent">
        Desarrollador Fullstack · PHP / Bootstrap · Java / Angular
      </p>
      <h1
        class="max-w-5xl font-display text-4xl font-extrabold leading-[0.95] md:text-6xl lg:text-7xl"
      >
        Rafael López
      </h1>
    </section>

    <section
      id="sobre-mi"
      class="scroll-mt-28 border-b border-white/10 py-14 md:py-20"
      aria-labelledby="sobre-mi-title"
    >
      <div
        class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start lg:gap-16"
      >
        <div class="max-w-md">
          <div
            class="group/photo relative aspect-[3/4] overflow-hidden border"
            style="border-color: var(--border);"
          >
            <Image
              src={profileImage}
              alt="Rafael López Plana"
              width={900}
              height={1200}
              class="absolute inset-0 h-full w-full object-cover saturate-95 transition duration-300 group-hover/photo:saturate-125"
            />
            <Image
              src={profileImage2}
              alt="Rafael López Plana"
              width={900}
              height={1200}
              class="crossfade-front absolute inset-0 h-full w-full object-cover saturate-95 transition duration-300 group-hover/photo:saturate-125"
            />
          </div>
        </div>

        <div class="space-y-8">
          <div class="space-y-4">
            <p class="text-xs uppercase tracking-[0.24em] text-white/50">
              Sobre mí
            </p>
            <h2
              id="sobre-mi-title"
              class="max-w-3xl font-display text-3xl font-bold leading-tight md:text-5xl"
            >
              La ventaja de empezar tarde.
            </h2>
            <p
              class="max-w-3xl text-lg leading-relaxed text-white/80 md:text-xl"
            >
              Años lidiando con la presión del mundo real en restauración me
              enseñaron a entender el negocio antes que el código, a comunicarme
              con claridad y a mantener la calma cuando los sistemas fallan.
            </p>
            <p
              class="max-w-3xl text-lg leading-relaxed text-white/80 md:text-xl"
            >
              Ahora combino esa visión con mi pasión por la tecnología
              construyendo aplicaciones robustas que ayuden a otros a resolver
              problemas reales.
            </p>
          </div>

          <a
            href="/web-site/blog/historia-transición"
            class="inline-block text-sm uppercase tracking-[0.16em] text-accent transition hover:text-white"
          >
            Saber más →
          </a>

          <div class="flex gap-4">
            <a
              href="https://www.linkedin.com/in/rafalopezzz/"
              target="_blank"
              rel="noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center border border-white/15 text-white/70 transition hover:border-accent hover:text-accent"
              aria-label="LinkedIn"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path></svg
              >
            </a>
            <a
              href="https://github.com/RafaLopezZz"
              target="_blank"
              rel="noreferrer"
              class="inline-flex h-10 w-10 items-center justify-center border border-white/15 text-white/70 transition hover:border-accent hover:text-accent"
              aria-label="GitHub"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                ></path></svg
              >
            </a>
          </div>
        </div>
      </div>
    </section>

    <section
      id="proyectos"
      class="scroll-mt-28 py-14 md:py-16"
      aria-labelledby="proyectos-title"
    >
      <div class="mb-8 flex items-end justify-between gap-4">
        <h2
          id="proyectos-title"
          class="font-display text-3xl font-bold md:text-5xl"
        >
          Proyectos en paralelo
        </h2>
        <span class="text-xs uppercase tracking-[0.2em] text-white/60">
          {projects.length} publicados
        </span>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {
          projects.map((project) => {
            const projectImage =
              projectImages[project.data.image as keyof typeof projectImages] ??
              cosechaEnCopeCover;

            return (
              <article class="group border border-white/15 bg-white/[0.02] transition hover:border-accent/70">
                <Image
                  src={projectImage}
                  alt={project.data.title}
                  width={1200}
                  height={720}
                  class="h-52 w-full object-cover opacity-80 saturate-75 transition duration-300 group-hover:opacity-100 group-hover:saturate-100"
                />

                <div class="space-y-4 p-6">
                  <div class="flex items-center justify-between gap-4">
                    <h3 class="font-display text-2xl font-bold">
                      {project.data.title}
                    </h3>
                    <time class="text-xs uppercase tracking-[0.18em] text-white/60">
                      {project.data.date.toLocaleDateString("es-ES", {
                        year: "numeric",
                        month: "short",
                      })}
                    </time>
                  </div>

                  <p class="text-sm leading-relaxed text-white/80">
                    {project.data.description}
                  </p>

                  <ul class="flex flex-wrap gap-2">
                    {project.data.techStack.map((tech: string) => (
                      <li class="text-xs text-accent">{tech}</li>
                    ))}
                  </ul>
                </div>

                <div class="p-4 pt-0">
                  <a
                    href="/web-site/blog/"
                    class="inline-block text-sm uppercase tracking-[0.16em] text-white transition group-hover:text-accent"
                  >
                    Saber más →
                  </a>
                </div>

                <div class="p-4 pt-0">
                  <a
                    href={project.data.githubUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="inline-block text-sm uppercase tracking-[0.16em] text-white transition group-hover:text-accent"
                  >
                    Ver en GitHub
                  </a>
                </div>
              </article>
            );
          })
        }
      </div>
    </section>

    <TimelineExperience
      id="experiencia"
      title="Experiencia"
      items={experience}
    />

    <TimelineEducation id="formacion" title="Formación Académica" items={education} />

    <SkillsPanel />

    <section
      id="cv"
      class="scroll-mt-28 border-t border-white/10 py-14 md:py-16"
      aria-labelledby="cv-title"
    >
      <div
        class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between"
      >
        <div class="space-y-3">
          <h2 id="cv-title" class="font-display text-3xl font-bold md:text-5xl">
            Currículum Vitae
          </h2>
          <p class="text-base leading-relaxed text-white/80">
            Descarga mi CV actualizado en PDF.
          </p>
        </div>

        <a
          href="/web-site/cv/lopez-plana-rafael-2026.pdf"
          download
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center border border-white/15 px-5 py-3 text-sm uppercase tracking-[0.16em] text-white transition hover:border-accent hover:text-accent"
        >
          Descargar CV
        </a>
      </div>
    </section>

    <ContactForm />

    <footer class="mt-20 border-t border-white/10 py-10 text-center text-sm text-white/50">
        © {new Date().getFullYear()} Hecho con ❤️, gracias a <a href="https://astro.build" target="_blank" rel="noreferrer" class="text-accent">Astro, </a> por Rafael López. Todos los derechos
        reservados.

  </main>
</BaseLayout>
