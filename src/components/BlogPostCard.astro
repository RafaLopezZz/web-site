---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<article class="group overflow-hidden border border-white/10 bg-white/[0.02] transition hover:border-accent/50">
  <a href={`/blog/${post.slug}/`} class="block" aria-label={`Leer ${post.data.title}`}>
    <Image
      src={post.data.cover}
      alt={post.data.coverAlt}
      width={1440}
      height={900}
      class="h-56 w-full object-cover opacity-85 transition duration-300 group-hover:opacity-100"
    />
  </a>

  <div class="space-y-4 p-6">
    <div class="flex items-center justify-between gap-4">
      <time class="text-xs uppercase tracking-[0.18em] text-white/50">
        {post.data.date.toLocaleDateString("es-ES", { day: "2-digit", month: "short", year: "numeric" })}
      </time>
      <span class="text-xs uppercase tracking-[0.18em] text-white/35">{post.data.tags.length} tags</span>
    </div>

    <div class="space-y-3">
      <h2 class="font-display text-2xl font-bold">
        <a href={`/blog/${post.slug}/`} class="transition hover:text-accent">{post.data.title}</a>
      </h2>
      <p class="text-sm leading-relaxed text-white/75">{post.data.excerpt}</p>
    </div>

    <ul class="flex flex-wrap gap-2">
      {post.data.tags.map((tag) => <li class="text-xs uppercase tracking-[0.14em] text-accent">{tag}</li>)}
    </ul>
  </div>
</article>
