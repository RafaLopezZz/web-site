---
import { Image } from "astro:assets";
import logo from "../assets/logo-cyan.svg";

const base = import.meta.env.BASE_URL;

const links = [
  { href: "/web-site/blog", label: "Blog" },
  { href: "#sobre-mi", label: "Sobre mí" },
  { href: "#experiencia", label: "Experiencia" },
  { href: "#educacion", label: "Educación" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#habilidades", label: "Habilidades" },
  { href: "#cv", label: "CV" },
  { href: "#contacto", label: "Contacto" },
];
---

<header id="site-header" class="sticky top-0 z-50 transition-all duration-300">
  <div class="editorial-container">
    <nav
      class="mt-4 flex items-center justify-between gap-6 border border-white/10 bg-white/[0.02] px-4 py-2.5 transition-all duration-300 md:px-6 md:py-3.5"
      aria-label="Principal"
    >
      <a
        href="/web-site"
        class="flex min-w-0 items-center gap-4 text-white"
        aria-label="Ir al inicio"
      >
        <Image
          src={logo}
          alt="Rafael López Plana"
          width={280}
          height={88}
          class="h-10 w-auto shrink-0 md:h-14 lg:h-16"
        />
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center border border-white/15 text-white md:hidden"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Abrir menú"
      >
        <span class="sr-only">Abrir menú</span>
        <span class="flex flex-col gap-1.5">
          <span class="block h-px w-5 bg-current"></span>
          <span class="block h-px w-5 bg-current"></span>
          <span class="block h-px w-5 bg-current"></span>
        </span>
      </button>

      <div
        id="nav-menu"
        class="nav-menu hidden md:block
         absolute left-0 top-full w-full
         border-t border-white/10 bg-[#0B0C10]
         px-4 py-6
         md:static md:w-auto md:border-0 md:bg-transparent md:p-0"
      >
        <ul
          class="flex flex-col gap-4 pt-4 text-sm uppercase tracking-[0.16em] text-white/70 md:flex-row md:items-center md:gap-6 md:pt-0"
        >
          {
            links.map((link) => (
              <li>
                <a
                  href={
                    link.href.startsWith("#")
                      ? `${base}${link.href}`
                      : link.href
                  }
                  class="nav-link transition hover:text-accent"
                  data-section-link={
                    link.href.startsWith("#") ? true : undefined
                  }
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  const header = document.querySelector("#site-header");
  const menu = document.querySelector("#nav-menu");
  const toggle = document.querySelector("#nav-toggle");
  const links = Array.from(document.querySelectorAll("[data-section-link]"));
  const path = window.location.pathname;
  const sections = links
    .map((link) => {
      const href = link.getAttribute("href");
      const hash = href?.includes("#") ? `#${href.split("#")[1]}` : href;
      return hash ? document.querySelector(hash) : null;
    })
    .filter(Boolean);

  const setScrolledState = () => {
    if (!header) return;
    header.dataset.scrolled = String(window.scrollY > 16);
  };

  const closeMenu = () => {
    if (
      !(menu instanceof HTMLElement) ||
      !(toggle instanceof HTMLButtonElement)
    )
      return;
    menu.classList.add("hidden");
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "Abrir menú");
  };

  if (toggle instanceof HTMLButtonElement && menu instanceof HTMLElement) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      menu.classList.toggle("hidden", isOpen);
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Abrir menú" : "Cerrar menú");
    });

    links.forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth < 768) closeMenu();
      });
    });
  }

  if (path === "/" && sections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          links.forEach((link) => {
            const href = link.getAttribute("href");
            const hash = href?.includes("#") ? `#${href.split("#")[1]}` : href;
            const isActive = hash === `#${entry.target.id}`;
            link.classList.toggle("text-accent", isActive);
            link.classList.toggle("text-white/70", !isActive);
            link.setAttribute("aria-current", isActive ? "page" : "false");
          });
        });
      },
      { rootMargin: "-35% 0px -45% 0px", threshold: 0.2 },
    );

    sections.forEach((section) => observer.observe(section));
  }

  document.querySelectorAll(".nav-link").forEach((link) => {
    const isBlog = link.getAttribute("href") === "/blog";
    if (isBlog && path.startsWith("/blog")) {
      link.classList.add("text-accent");
      link.classList.remove("text-white/70");
      link.setAttribute("aria-current", "page");
    }
  });

  setScrolledState();
  window.addEventListener("scroll", setScrolledState, { passive: true });
  window.addEventListener("resize", () => {
    if (
      window.innerWidth >= 768 &&
      menu instanceof HTMLElement &&
      toggle instanceof HTMLButtonElement
    ) {
      menu.classList.remove("hidden");
      toggle.setAttribute("aria-expanded", "false");
    } else if (window.innerWidth < 768) {
      closeMenu();
    }
  });
</script>
