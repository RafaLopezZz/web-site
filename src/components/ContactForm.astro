---
import { ENV } from "../config/env";
---

<section
  id="contacto"
  class="scroll-mt-28 border-t border-white/10 py-14 md:py-16"
  aria-labelledby="contacto-title"
>
  <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="space-y-4">
      <h2
        id="contacto-title"
        class="font-display text-3xl font-bold md:text-5xl"
      >
        Contacto
      </h2>
      <p class="max-w-xl text-base leading-relaxed text-white/80">
        Si quieres hablar de una oportunidad, colaboración o producto digital,
        escríbeme y te responderé lo antes posible.
      </p>
      <p class="text-sm text-white/50">
        O si lo prefieres, puedes enviarme un correo a <a
          class="text-accent"
          href="mailto:rlp.murcia@gmail.com">rlp.murcia@gmail.com</a
        >
      </p>
    </div>

    <form
      id="contact-form"
      class="space-y-5"
      data-web3forms-key={ENV.WEB3FORMS_KEY}
      data-hcaptcha-sitekey={ENV.HCAPTCHA_SITEKEY}
      novalidate
    >
      <input type="hidden" name="access_key" value={ENV.WEB3FORMS_KEY} />
      <input
        type="hidden"
        name="from_name"
        value="Portfolio Rafael López Plana"
      />

      <div class="honeypot" aria-hidden="true">
        <label for="botcheck">No rellenar este campo</label>
        <input id="botcheck" name="botcheck" autocomplete="off" tabindex="-1" />
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        <label class="space-y-2 text-sm text-white/75" for="name">
          <span>Nombre*</span>
          <input
            id="name"
            name="name"
            maxlength="100"
            required
            class="w-full border border-white/10 bg-white/[0.02] px-4 py-3 text-white outline-none transition focus:border-accent"
          />
        </label>

        <label class="space-y-2 text-sm text-white/75" for="email">
          <span>Email*</span>
          <input
            id="email"
            name="email"
            type="email"
            maxlength="150"
            required
            class="w-full border border-white/10 bg-white/[0.02] px-4 py-3 text-white outline-none transition focus:border-accent"
          />
        </label>
      </div>

      <label class="space-y-2 text-sm text-white/75" for="contact-subject">
        <span>Asunto</span>
        <input
          id="contact-subject"
          name="subject"
          maxlength="150"
          class="w-full border border-white/10 bg-white/[0.02] px-4 py-3 text-white outline-none transition focus:border-accent"
        />
      </label>

      <label class="space-y-2 text-sm text-white/75" for="message">
        <span>Mensaje*</span>
        <textarea
          id="message"
          name="message"
          maxlength="2000"
          rows="7"
          required
          class="w-full resize-y border border-white/10 bg-white/[0.02] px-4 py-3 text-white outline-none transition focus:border-accent"
        ></textarea>
      </label>

      <div class="space-y-2">
        <h-captcha
          id="contact-hcaptcha"
          site-key={ENV.HCAPTCHA_SITEKEY}
          theme="dark"
          tabindex="0"></h-captcha>
        <p
          id="contact-captcha-error"
          class="text-sm text-red-300"
          role="alert"
          aria-live="polite"
        >
        </p>
      </div>

      <div
        class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
      >
        <button
          id="contact-submit"
          type="submit"
          class="inline-flex items-center justify-center border border-white/15 px-5 py-3 text-sm uppercase tracking-[0.16em] text-white transition hover:border-accent hover:text-accent disabled:cursor-not-allowed disabled:opacity-50"
        >
          Enviar mensaje
        </button>
        <p
          id="contact-status"
          class="text-sm text-white/60"
          role="alert"
          aria-live="polite"
        >
        </p>
      </div>
    </form>
  </div>
</section>

<style>
  .honeypot {
    display: none;
  }
</style>

<script>
  import "@hcaptcha/vanilla-hcaptcha";

  const form = document.querySelector<HTMLFormElement>("#contact-form");
  const submitButton =
    document.querySelector<HTMLButtonElement>("#contact-submit");
  const status = document.querySelector<HTMLElement>("#contact-status");
  const captchaElement =
    document.querySelector<HTMLElement>("#contact-hcaptcha");
  const captchaError = document.querySelector<HTMLElement>(
    "#contact-captcha-error",
  );

  const EMAIL_REGEX =
    /^(?:[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+|"(?:[\u0001-\u0008\u000b\u000c\u000e-\u001f\u0021\u0023-\u005b\u005d-\u007f]|\\[\u0001-\u0009\u000b\u000c\u000e-\u007f])*")@(?:(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,63}|\[(?:(?:25[0-5]|2[0-4]\d|1?\d?\d)\.){3}(?:25[0-5]|2[0-4]\d|1?\d?\d)\])$/;
  const limits = {
    email: 150,
    message: 2000,
    name: 100,
    subject: 150,
  };
  const states = {
    error: "error",
    idle: "idle",
    sending: "sending",
    success: "success",
  };

  const setCaptchaError = (message = "") => {
    if (!(captchaError instanceof HTMLElement)) return;
    captchaError.textContent = message;
  };

  const setStatus = (state: string, message = "") => {
    if (!status) return;

    status.textContent = message;
    status.dataset.state = state;
    status.classList.toggle("text-red-300", state === states.error);
    status.classList.toggle("text-emerald-300", state === states.success);
    status.classList.toggle(
      "text-white/60",
      state === states.idle || state === states.sending,
    );
  };

  const validateFields = ({
    botcheck,
    email,
    message,
    name,
    subject,
  }: Record<string, string>) => {
    if (botcheck) {
      return { silentAbort: true };
    }

    if (!name || !message || !email) {
      return {
        message: "Completa los campos obligatorios.",
        valid: false,
      };
    }

    if (
      name.length > limits.name ||
      email.length > limits.email ||
      message.length > limits.message ||
      subject.length > limits.subject
    ) {
      return {
        message: "Uno de los campos supera la longitud permitida.",
        valid: false,
      };
    }

    if (!EMAIL_REGEX.test(email)) {
      return {
        message: "Introduce un email válido.",
        valid: false,
      };
    }

    return { valid: true };
  };

  if (
    form instanceof HTMLFormElement &&
    submitButton instanceof HTMLButtonElement &&
    captchaElement instanceof HTMLElement
  ) {
    let isSubmitting = false;
    let captchaToken = "";

    captchaElement.addEventListener("verified", (event: Event) => {
      const token =
        (event as CustomEvent).detail?.token ?? (event as any).token;
      captchaToken = typeof token === "string" ? token : "";
      setCaptchaError("");
    });

    captchaElement.addEventListener("expired", () => {
      captchaToken = "";
      setCaptchaError("El captcha ha caducado. Complétalo de nuevo.");
    });

    captchaElement.addEventListener("challenge-expired", () => {
      captchaToken = "";
      setCaptchaError("El reto ha caducado. Vuelve a completar el captcha.");
    });

    captchaElement.addEventListener("error", () => {
      captchaToken = "";
      setCaptchaError("No se pudo validar el captcha. Inténtalo otra vez.");
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (isSubmitting) {
        return;
      }

      const formData = new FormData(form);
      const name = String(formData.get("name") ?? "").trim();
      const email = String(formData.get("email") ?? "").trim();
      const message = String(formData.get("message") ?? "").trim();
      const subject = String(formData.get("subject") ?? "").trim();
      const botcheck = String(formData.get("botcheck") ?? "").trim();
      const validation = validateFields({
        botcheck,
        email,
        message,
        name,
        subject,
      });

      if (validation.silentAbort) {
        return;
      }

      if (!validation.valid) {
        setStatus(states.error, validation.message);
        return;
      }

      const hiddenCaptchaToken = String(
        formData.get("h-captcha-response") ?? "",
      ).trim();
      const effectiveCaptchaToken = hiddenCaptchaToken || captchaToken;

      if (!effectiveCaptchaToken) {
        setCaptchaError("Completa el captcha antes de enviar el formulario.");
        setStatus(states.error, "Debes completar el captcha para continuar.");
        return;
      }

      isSubmitting = true;
      submitButton.disabled = true;
      setCaptchaError("");
      setStatus(states.sending, "Enviando...");

      try {
        // Lee todo el FormData como objeto plano y añade el captcha
        const formData = new FormData(form);
        const object = Object.fromEntries(formData.entries());

        // Sobreescribe con los valores ya saneados y el captcha correcto
        object["name"] = name;
        object["email"] = email;
        object["subject"] = subject;
        object["message"] = message;
        object["h-captcha-response"] = effectiveCaptchaToken;
        delete object["g-recaptcha-response"];

        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(object),
        });

        if (!response.ok) {
          throw new Error("Network response was not ok");
        }

        const result = await response.json();
        if (!result.success) {
          throw new Error(result.message || "Submission failed");
        }

        form.reset();
        captchaToken = "";
        (captchaElement as any).reset?.();
        setStatus(
          states.success,
          "¡Mensaje enviado con éxito! Gracias por contactarme.",
        );
        
      } catch (error) {
        console.error(error);
        captchaToken = "";
        (captchaElement as any).reset?.();
        setStatus(
          states.error,
          "No se pudo enviar. Prueba de nuevo o escribe a rlp.murcia@gmail.com.",
        );
      } finally {
        isSubmitting = false;
        submitButton.disabled = false;
      }
    });
  }
</script>
