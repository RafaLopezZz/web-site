---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "RafaLopezZz | Desarrollador Fullstack & Técnico de Sistemas",
  description = "Portfolio donde expresar mis conocimientos y proyectos como desarrollador fullstack y técnico de sistemas. Aquí encontrarás una muestra de mi trabajo, habilidades y experiencia en el mundo de la tecnología."
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Syne:wght@500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-ink">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:border focus:border-accent focus:bg-ink focus:px-4 focus:py-2 focus:text-white"
    >
      Saltar al contenido
    </a>
    <slot />
  </body>
</html>
