---
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    
    <!-- Favicon con base dinámica -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    
    <!-- Meta generator de Astro -->
    <meta name="generator" content={Astro.generator} />
    
    <!-- Título dinámico si pasas un prop -->
    <title>{Astro.props.title ?? "Rafael López Plana | Fullstack Developer"}</title>
    
    <!-- Open Graph para compartir en LinkedIn/Twitter -->
    <meta property="og:title" content="Rafael López Plana | Fullstack Developer" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.site?.href ?? 'https://rafalopezzz.github.io/web-site/'} />
    <meta property="og:image" content={`${import.meta.env.BASE_URL}og-image.jpg`} />
    
    <style is:global>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
      }
    </style>
  </head>
  <body>
    <ViewTransitions />
    <slot />
  </body>
</html>

